# Copy to .env.local and fill in values.

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin (comma-separated emails)
ADMIN_EMAILS=

# Cloudinary — Dashboard → API Keys (Product environment credentials)
# Use cloud name + API Key + API Secret. The secret is only used on the server to sign uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Optional default folder for product images (must be included in the signature)
# CLOUDINARY_UPLOAD_FOLDER=gatumis/products
